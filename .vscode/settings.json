{
    "java.configuration.updateBuildConfiguration": "disabled",
    "java.import.gradle.enabled": false,
    "java.import.exclusions": [
        "**/build/**",
        "**/.dart_tool/**",
        "**/.pub-cache/**",
        "**/android/.gradle/**"
    ],
    "search.exclude": {
        "**/build/**": true,
        "**/.dart_tool/**": true
    },
    "files.watcherExclude": {
        "**/build/**": true,
        "**/.dart_tool/**": true
    }
}