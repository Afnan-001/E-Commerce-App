rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /cartItems/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /savedItems/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create, update: if isSignedIn() &&
          request.auth.uid == reviewId &&
          request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && request.auth.uid == reviewId;
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /home_sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /store_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount', 'updatedAt']) &&
        request.resource.data.usageCount == resource.data.usageCount + 1 &&
        request.resource.data.code == resource.data.code &&
        request.resource.data.discountType == resource.data.discountType &&
        request.resource.data.discountValue == resource.data.discountValue &&
        request.resource.data.applicableCategoryIds == resource.data.applicableCategoryIds &&
        request.resource.data.applicableProductIds == resource.data.applicableProductIds &&
        request.resource.data.minCartValue == resource.data.minCartValue &&
        request.resource.data.expiryDate == resource.data.expiryDate &&
        request.resource.data.usageLimit == resource.data.usageLimit &&
        request.resource.data.isActive == resource.data.isActive &&
        request.resource.data.createdAt == resource.data.createdAt
      );
    }

    match /orders/{orderId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);

      allow update, delete: if isAdmin();
    }
  }
}
